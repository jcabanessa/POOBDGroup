package poodbgroupDAO;

import poodbgroupModelo.Cliente;
import poodbgroupModelo.ClienteEstandar;
import poodbgroupModelo.ClientePremium;
import java.sql.*;
import java.util.ArrayList;
import java.util.List;

public class ClienteDAO {

    // Método para insertar un nuevo cliente (con transacción)
    public void insertar(Cliente cliente) throws SQLException {
        String sql = "{call InsertarCliente(?, ?, ?, ?, ?, ?)}";

        try (Connection conn = ConexionDB.obtenerConexion();
             CallableStatement stmt = conn.prepareCall(sql)) {

            // Configurar auto-commit false para la transacción
            conn.setAutoCommit(false);

            try {
                stmt.setString(1, cliente.getNombre());
                stmt.setString(2, cliente.getDomicilio());
                stmt.setString(3, cliente.getNif());
                stmt.setString(4, cliente.getEmail());
                stmt.setString(5, cliente.tipoCliente().toLowerCase());
                stmt.setDouble(6, cliente.calcAnual());

                stmt.executeUpdate();

                // Commit de la transacción
                conn.commit();

            } catch (SQLException e) {
                // Rollback en caso de error
                conn.rollback();
                throw e;
            } finally {
                conn.setAutoCommit(true);
            }
        }
    }

    // Método para buscar cliente por email (procedimiento almacenado)
    public Cliente buscarPorEmail(String email) throws SQLException {
        String sql = "{call BuscarClientePorEmail(?)}";
        Cliente cliente = null;

        try (Connection conn = ConexionDB.obtenerConexion();
             CallableStatement stmt = conn.prepareCall(sql)) {

            stmt.setString(1, email);

            try (ResultSet rs = stmt.executeQuery()) {
                if (rs.next()) {
                    cliente = mapearCliente(rs);
                }
            }
        }

        return cliente;
    }

    // Método para listar todos los clientes
    public List<Cliente> listarTodos() throws SQLException {
        List<Cliente> clientes = new ArrayList<>();
        String sql = "{call ListarTodosClientes()}";

        try (Connection conn = ConexionDB.obtenerConexion();
             CallableStatement stmt = conn.prepareCall(sql);
             ResultSet rs = stmt.executeQuery()) {

            while (rs.next()) {
                clientes.add(mapearCliente(rs));
            }
        }

        return clientes;
    }

    // Método para listar clientes estándar
    public List<Cliente> listarEstandar() throws SQLException {
        List<Cliente> clientes = new ArrayList<>();
        String sql = "{call ListarClientesPorTipo('estandar')}";

        try (Connection conn = ConexionDB.obtenerConexion();
             CallableStatement stmt = conn.prepareCall(sql);
             ResultSet rs = stmt.executeQuery()) {

            while (rs.next()) {
                clientes.add(mapearCliente(rs));
            }
        }

        return clientes;
    }

    // Método para listar clientes premium
    public List<Cliente> listarPremium() throws SQLException {
        List<Cliente> clientes = new ArrayList<>();
        String sql = "{call ListarClientesPorTipo('premium')}";

        try (Connection conn = ConexionDB.obtenerConexion();
             CallableStatement stmt = conn.prepareCall(sql);
             ResultSet rs = stmt.executeQuery()) {

            while (rs.next()) {
                clientes.add(mapearCliente(rs));
            }
        }

        return clientes;
    }

    // Método para actualizar cliente (con transacción)
    public void actualizar(Cliente cliente) throws SQLException {
        String sql = "{call ActualizarCliente(?, ?, ?, ?, ?, ?, ?)}";

        try (Connection conn = ConexionDB.obtenerConexion();
             CallableStatement stmt = conn.prepareCall(sql)) {

            conn.setAutoCommit(false);

            try {
                stmt.setInt(1, obtenerIdPorEmail(cliente.getEmail()));
                stmt.setString(2, cliente.getNombre());
                stmt.setString(3, cliente.getDomicilio());
                stmt.setString(4, cliente.getNif());
                stmt.setString(5, cliente.getEmail());
                stmt.setString(6, cliente.tipoCliente().toLowerCase());
                stmt.setDouble(7, cliente.calcAnual());

                stmt.executeUpdate();
                conn.commit();

            } catch (SQLException e) {
                conn.rollback();
                throw e;
            } finally {
                conn.setAutoCommit(true);
            }
        }
    }

    // Método para eliminar cliente (con transacción y verificación de pedidos)
    public void eliminar(String email) throws SQLException {
        String sql = "{call EliminarCliente(?)}";

        try (Connection conn = ConexionDB.obtenerConexion();
             CallableStatement stmt = conn.prepareCall(sql)) {

            conn.setAutoCommit(false);

            try {
                stmt.setString(1, email);
                stmt.executeUpdate();
                conn.commit();

            } catch (SQLException e) {
                conn.rollback();
                throw new SQLException("No se puede eliminar el cliente. " +
                                       "Posiblemente tiene pedidos asociados.", e);
            } finally {
                conn.setAutoCommit(true);
            }
        }
    }

    // Método para verificar si existe un cliente
    public boolean existeCliente(String email) throws SQLException {
        String sql = "{call ExisteCliente(?)}";
        boolean existe = false;

        try (Connection conn = ConexionDB.obtenerConexion();
             CallableStatement stmt = conn.prepareCall(sql)) {

            stmt.setString(1, email);

            try (ResultSet rs = stmt.executeQuery()) {
                if (rs.next()) {
                    existe = rs.getInt(1) > 0;
                }
            }
        }

        return existe;
    }

    // Método auxiliar para obtener el ID por email
    private int obtenerIdPorEmail(String email) throws SQLException {
        String sql = "SELECT id FROM cliente WHERE email = ?";

        try (Connection conn = ConexionDB.obtenerConexion();
             PreparedStatement stmt = conn.prepareStatement(sql)) {

            stmt.setString(1, email);

            try (ResultSet rs = stmt.executeQuery()) {
                if (rs.next()) {
                    return rs.getInt("id");
                } else {
                    throw new SQLException("Cliente no encontrado con email: " + email);
                }
            }
        }
    }

    // Método auxiliar para mapear ResultSet a objeto Cliente
    private Cliente mapearCliente(ResultSet rs) throws SQLException {
        String nombre = rs.getString("nombre");
        String domicilio = rs.getString("domicilio");
        String nif = rs.getString("nif");
        String email = rs.getString("email");
        String tipo = rs.getString("tipo");

        Cliente cliente;

        if ("premium".equalsIgnoreCase(tipo)) {
            cliente = new ClientePremium(nombre, domicilio, nif, email);
        } else {
            cliente = new ClienteEstandar(nombre, domicilio, nif, email);
        }

        return cliente;
    }
}

