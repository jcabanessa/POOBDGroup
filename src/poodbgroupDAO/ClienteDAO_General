USE tienda_online;

-- Procedimiento para insertar cliente
DELIMITER //
CREATE PROCEDURE InsertarCliente(
    IN p_nombre VARCHAR(50),
    IN p_domicilio VARCHAR(100),
    IN p_nif VARCHAR(10),
    IN p_email VARCHAR(30),
    IN p_tipo ENUM('estandar', 'premium'),
    IN p_cuota_anual DECIMAL(10,2)
)
BEGIN
    INSERT INTO cliente (nombre, domicilio, nif, email, tipo, cuota_anual)
    VALUES (p_nombre, p_domicilio, p_nif, p_email, p_tipo, p_cuota_anual);
END //
DELIMITER ;

-- Procedimiento para buscar cliente por email
DELIMITER //
CREATE PROCEDURE BuscarClientePorEmail(
    IN p_email VARCHAR(30)
)
BEGIN
    SELECT * FROM cliente WHERE email = p_email;
END //
DELIMITER ;

-- Procedimiento para listar todos los clientes
DELIMITER //
CREATE PROCEDURE ListarTodosClientes()
BEGIN
    SELECT * FROM cliente ORDER BY nombre;
END //
DELIMITER ;

-- Procedimiento para listar clientes por tipo
DELIMITER //
CREATE PROCEDURE ListarClientesPorTipo(
    IN p_tipo VARCHAR(10)
)
BEGIN
    SELECT * FROM cliente WHERE tipo = p_tipo ORDER BY nombre;
END //
DELIMITER ;

-- Procedimiento para actualizar cliente
DELIMITER //
CREATE PROCEDURE ActualizarCliente(
    IN p_id INT,
    IN p_nombre VARCHAR(50),
    IN p_domicilio VARCHAR(100),
    IN p_nif VARCHAR(10),
    IN p_email VARCHAR(30),
    IN p_tipo ENUM('estandar', 'premium'),
    IN p_cuota_anual DECIMAL(10,2)
)
BEGIN
    UPDATE cliente
    SET nombre = p_nombre,
        domicilio = p_domicilio,
        nif = p_nif,
        email = p_email,
        tipo = p_tipo,
        cuota_anual = p_cuota_anual
    WHERE id = p_id;
END //
DELIMITER ;

-- Procedimiento para eliminar cliente (verifica pedidos)
DELIMITER //
CREATE PROCEDURE EliminarCliente(
    IN p_email VARCHAR(30)
)
BEGIN
    DECLARE v_id INT;
    DECLARE v_tiene_pedidos INT;

    -- Obtener ID del cliente
    SELECT id INTO v_id FROM cliente WHERE email = p_email;

    -- Verificar si tiene pedidos
    SELECT COUNT(*) INTO v_tiene_pedidos
    FROM pedido WHERE cliente_id = v_id;

    -- Si no tiene pedidos, eliminar
    IF v_tiene_pedidos = 0 THEN
        DELETE FROM cliente WHERE email = p_email;
    ELSE
        SIGNAL SQLSTATE '45000'
        SET MESSAGE_TEXT = 'No se puede eliminar cliente con pedidos asociados';
    END IF;
END //
DELIMITER ;

-- Procedimiento para verificar existencia de cliente
DELIMITER //
CREATE PROCEDURE ExisteCliente(
    IN p_email VARCHAR(30)
)
BEGIN
    SELECT COUNT(*) FROM cliente WHERE email = p_email;
END //
DELIMITER ;